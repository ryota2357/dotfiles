{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "permissions": {
    "allow": [
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo doc *)",
      "Bash(cargo fmt *)",
      "Bash(cargo test *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh run list *)",
      "Bash(gh run status *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(git blame *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git ls-tree  *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(nix build *)",
      "Bash(nix fmt *)",
      "Bash(nix log *)",
      "Bash(nix-build *)",
      "Bash(pwd)",
      "Bash(rg *)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.renovatebot.com)",
      "WebFetch(domain:ryota2357.com)"
    ],
    "deny": [
      "Bash(sudo *)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/coding-agent/claude-code/statusline.sh"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/coding-agent/claude-code/hooks/notification.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/coding-agent/claude-code/hooks/stop.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
